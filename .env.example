APP_HOST=127.0.0.1
APP_PORT=8765
APP_TIMEZONE=Asia/Jerusalem
DEMO_MODE=true
SCHEDULER_ENABLED=true
BRIEFING_HOUR=8

# Optional OpenAI enrichment. Leave OPENAI_MODEL empty to use deterministic local logic only.
OPENAI_API_KEY=
OPENAI_MODEL=

# Google Workspace OAuth credentials. Use read-only Gmail and Calendar scopes.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8765/oauth/google/callback
GOOGLE_TOKEN_PATH=data/google_oauth_tokens.json
GOOGLE_OAUTH_STATE_PATH=data/google_oauth_state.json
GOOGLE_ENABLE_WRITE_ACTIONS=false
GOOGLE_REFRESH_TOKEN=
GOOGLE_ACCESS_TOKEN=
GOOGLE_CALENDAR_ID=primary

# Microsoft 365 delegated OAuth credentials.
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REFRESH_TOKEN=
MS_TENANT_ID=common
MS_GRAPH_ACCESS_TOKEN=
MS_REDIRECT_URI=http://127.0.0.1:8765/oauth/microsoft/callback
MS_TOKEN_PATH=data/microsoft_oauth_tokens.json
MS_OAUTH_STATE_PATH=data/microsoft_oauth_state.json
MS_ENABLE_WRITE_ACTIONS=false

# Outbound briefing channels.
SLACK_WEBHOOK_URL=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TO=
